    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug",
            "request": "launch",
            "type": "pwa-node",
            "program": "${workspaceFolder}/src/mod.ts",
            "cwd": "${workspaceFolder}",
            "runtimeExecutable": "deno",
            "runtimeArgs": [
                "run",
                "--inspect",
                "--allow-all",
                "--import-map=./import_map.json"
            ],
            "envFile": "${workspaceFolder}/.env",
            "attachSimplePort": 9229
        }
    ]
}